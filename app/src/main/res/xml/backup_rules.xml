<?xml version="1.0" encoding="utf-8"?>
<!--
   Breath Space stores mood check-ins, breathing session history, and reminder
   preferences locally. Keep those records off cloud backup/restore surfaces so
   the privacy policy's local-only promise matches runtime behavior.
-->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
</full-backup-content>
